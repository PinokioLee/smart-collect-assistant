# Smart Collect Assistant - 환경 변수 (.env 로 복사 후 채우기)

# --- Azure OpenAI (메일 분석 LLM) ---
# 비워두면 메일 분석은 휴리스틱으로 자동 폴백합니다.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Langfuse (선택적 추적) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- 기능 토글 ---
USE_MOCK_EMAIL=true
USE_LANGFUSE=false
USE_RAG=false

# --- Email sending ---
# mock: 실제 발송 없이 발송 이력만 생성
# gmail: Gmail API OAuth 로 실제 메일 발송
EMAIL_SEND_MODE=mock
GMAIL_CREDENTIALS_FILE=
GMAIL_TOKEN_FILE=data/gmail_token.json
GMAIL_SENDER=

# --- Organization directory (optional) ---
# name,dept,email 열의 UTF-8 CSV 또는 동일 키의 JSON 배열. 미설정 시 시연용 내장 조직도.
DIRECTORY_FILE=

# --- Gmail inbox reading / autonomous action ---
EMAIL_READ_MODE=mock
GMAIL_READ_TOKEN_FILE=data/gmail_read_token.json
# true여도 아래 허용 도메인·신뢰도·근거 정책을 모두 통과한 단순 취합요청만 발송
AUTO_SEND_ENABLED=false
AUTO_SEND_MIN_CONFIDENCE=0.90
AUTO_SEND_ALLOWED_DOMAINS=company.com
