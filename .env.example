# Smart Collect Assistant - 환경 변수 (.env 로 복사 후 채우기)

# --- Azure OpenAI (메일 분석 LLM) ---
# 비워두면 메일 분석은 휴리스틱으로 자동 폴백합니다.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Langfuse (선택적 추적) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- 기능 토글 ---
USE_MOCK_EMAIL=true
USE_LANGFUSE=false
USE_RAG=false
