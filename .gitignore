# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Env / secrets
.env
*.local
# Gmail OAuth 자격증명/토큰 — 절대 커밋 금지 (클라이언트 시크릿)
data/credentials.json
data/client_secret*.json
data/gmail_token.json
data/gmail_read_token.json

# Data: ignore generated outputs & uploads & samples (regenerable)
data/merged_files/*
data/error_reports/*
data/updated_files/*
data/uploads/
data/templates/
data/samples/
data/style_samples/
data/traces/*
!data/traces/.gitkeep
# 수신함 파이프라인 런타임 저장소(SQLite) + 스케줄 설정
data/*.db
data/schedule_config.json
!data/merged_files/.gitkeep
!data/error_reports/.gitkeep
# 단, 실측 벤치마크 지표(JSON)는 추적 (발표 근거)
!data/benchmark_metrics.json

# Node / frontend
node_modules/
frontend/dist/
frontend/*.tsbuildinfo
frontend/**/*.tsbuildinfo
frontend/vite.config.d.ts

# Logs
logs/
*.log

# OS
Thumbs.db
.DS_Store

# Office lock files (created while a doc is open)
~$*

# Presentation intermediates
presentation/unpacked/
presentation/render/
